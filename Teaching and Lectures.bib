@article{cowleyInvisibleSportswomenSex2021,
  title = {``{{Invisible Sportswomen}}'': {{The Sex Data Gap}} in {{Sport}} and {{Exercise Science Research}}},
  shorttitle = {``{{Invisible Sportswomen}}''},
  author = {Cowley, Emma S. and Olenick, Alyssa A. and McNulty, Kelly L. and Ross, Emma Z.},
  year = 2021,
