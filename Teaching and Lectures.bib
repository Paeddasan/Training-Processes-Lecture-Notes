@article{mullinsGenomicsPersonalizedNutrition2020,
  title = {Genomics in {{Personalized Nutrition}}: {{Can You}} ``{{Eat}} for {{Your Genes}}''?},
  shorttitle = {Genomics in {{Personalized Nutrition}}},
  author = {Mullins, Veronica A. and Bresette, William and Johnstone, Laurel and Hallmark, Brian and Chilton, Floyd H.},
  year = 2020,
