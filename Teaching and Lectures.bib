@article{floreyPatientPreferencesSingle2009,
  title = {Patient Preferences for Single Rooms or Shared Accommodation in a District General Hospital},
  author = {Florey, L. and Flynn, R. and Isles, C.},
  year = 2009,
  month = jan,
  journal = {Scottish medical journal},
  volume = {54},
  number = {2},
  pages = {5--8},
  issn = {0036-9330},
  doi = {10.1258/rsmsmj.54.2.5},
  abstract = {OBJECTIVES  To determine whether patients who have used a Scottish district general hospital would prefer single or shared accommodation on a future admission.  METHODS  We surveyed 80 in-patients in January 2008 in order to obtain 20 medical and 20 surgical patients in single rooms and the same number in shared accommodation. Each patient received a seven point questionnaire that had been validated in another centre.  RESULTS  Forty four men and 36 women, median 64 years, who had been in hospital for a median of 4.5 days (range 1 to 53 days) participated in the survey. Seventy per cent of patients in shared and 40\% of patients in single rooms said they would prefer shared accommodation during a future hospital admission. Those expressing a preference for shared accommodation were older (median age 68 versus 58 years) and had been in hospital for longer (median 5.5 versus 3.5 days) than those who said they would prefer a single room.  CONCLUSIONS  It is likely that the desire for company among older people who have to spend a week or more in hospital is driving the responses we obtained. Our findings do not support claims that the argument in favour of 100\% single rooms is 'overwhelming'.},
  pmid = {19530493},
  keywords = {/unread}
}

