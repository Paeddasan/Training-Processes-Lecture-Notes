@article{gattererPracticingSportCold2021,
  title = {Practicing {{Sport}} in {{Cold Environments}}: {{Practical Recommendations}} to {{Improve Sport Performance}} and {{Reduce Negative Health Outcomes}}},
  shorttitle = {Practicing {{Sport}} in {{Cold Environments}}},
  author = {Gatterer, Hannes and D{\"u}nnwald, Tobias and Turner, Rachel and Csapo, Robert and Schobersberger, Wolfgang and Burtscher, Martin and Faulhaber, Martin and Kennedy, Michael D.},
  year = 2021,
  month = jan,
  journal = {International Journal of Environmental Research and Public Health},
  volume = {18},
  number = {18},
  pages = {9700},
  publisher = {Multidisciplinary Digital Publishing Institute},
  issn = {1660-4601},
  doi = {10.3390/ijerph18189700},
  urldate = {2023-02-03},
  abstract = {Although not a barrier to perform sport, cold weather environments (low ambient temperature, high wind speeds, and increased precipitation, i.e., rain/water/snow) may influence sport performance. Despite the obvious requirement for practical recommendations and guidelines to better facilitate training and competition in such cold environments, the current scientific evidence-base is lacking. Nonetheless, this review summarizes the current available knowledge specifically related to the physiological impact of cold exposure, in an attempt to provide practitioners and coaches alike with practical recommendations to minimize any potential negative performance effects, mitigate health issues, and best optimize athlete preparation across various sporting disciplines. Herein, the review is split into sections which explore some of the key physiological effects of cold exposure on performance (i.e., endurance exercise capacity and explosive athletic power), potential health issues (short-term and long-term), and what is currently known with regard to best preparation or mitigation strategies considered to negate the potential negative effects of cold on performance. Specific focus is given to ``winter'' sports that are usually completed in cold environments and practical recommendations for physical preparation.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  langid = {english},
  keywords = {/unread,athlete,cold exposure,exercise performance,health,warm-ups},
  file = {C:\Users\Paedd\Zotero\storage\7P2VGMUA\Gatterer et al. - 2021 - Practicing Sport in Cold Environments Practical R.pdf}
}

@article{gavandaOptimizingResistanceTraining2025,
  title = {Optimizing {{Resistance Training Outcomes}}: {{Comparing In-Person Supervision}}, {{Online Coaching}}, and {{Self-Guided Approaches}}: {{A Randomized Controlled Trial}}},
  shorttitle = {Optimizing {{Resistance Training Outcomes}}},
  author = {Gavanda, Simon and Held, Steffen and Schrey, Sascha and Oberwetter, Katharina and Lazzaro, Pier-Gino M. and Pergelt, Markus and Geisler, Stephan},
  year = 2025,
  month = nov,
  journal = {The Journal of Strength \& Conditioning Research},
  volume = {39},
  number = {11},
  pages = {1129},
  issn = {1064-8011},
  doi = {10.1519/JSC.0000000000005216},
  urldate = {2025-10-29},
  abstract = {Gavanda, S, Held, S, Schrey, S, Oberwetter, K, Lazzaro, P-GM, Pergelt, M, and Geisler, S. Optimizing resistance training outcomes: comparing in-person supervision, online coaching, and self-guided approaches: a randomized controlled trial. J Strength Cond Res 39(11): 1129--1137, 2025---This randomized, parallel-group trial investigated the effects of supervised (SUP), app-guided (APP), and self-guided (PDF) 10-week, thrice-weekly full-body resistance training (RT) on strength, body composition, well-being, and supervision satisfaction (S-SRQ) in trained men and women (n = 79, 48\% women; 30.7 \textpm{} 7.8 years, 1.75 \textpm{} 0.1 m, 77.5 \textpm{} 17.5 kg). Adherence was highest in SUP (88.2\%), followed by APP (81.2\%) and PDF (52.2\%). At p {$\leq$} 0.05, body mass (+1.8 \textpm{} 1.9 kg, p = 0.006) and fat-free mass (+1.4 \textpm{} 0.9 kg, p {$\leq$} 0.001) increased significantly in SUP. Muscle mass gains were observed in SUP (+1.4 \textpm{} 0.9 kg, p = 0.009) and PDF (+0.9 \textpm{} 1.3 kg, p = 0.047). All groups improved squat 1-repetition maximum (1RM) (SUP: +26.6 \textpm{} 6.5 kg, p {$\leq$} 0.001; APP: +19.2 \textpm{} 11.0 kg, p {$\leq$} 0.001; PDF: +19.4 \textpm{} 11.7 kg, p {$\leq$} 0.001) and bench press 1RM (SUP: +9.1 \textpm{} 3.5 kg, p {$\leq$} 0.001; APP: +8.2 \textpm{} 4.0 kg, p {$\leq$} 0.001; PDF: +7.7 \textpm{} 5.8 kg, p {$\leq$} 0.001). Supervised showed significantly greater squat gains than APP and PDF (p {$\leq$} 0.044). Well-being (WHO-5) improved in SUP (+15.7 \textpm{} 16.2 points, p {$\leq$} 0.001) and PDF (+9.0 \textpm{} 20.4 points, p = 0.032). Satisfaction with supervision was significantly higher in SUP (96.7 \textpm{} 4.3\%) than in APP (92.0 \textpm{} 7.1\%, p = 0.005). In conclusion, supervised RT resulted in superior improvements in strength, body composition, well-being, and supervision satisfaction compared with app-guided or self-guided training. Although APP and PDF resulted in some positive effects, their magnitude was generally smaller. These findings underscore the value of in-person coaching in optimizing RT outcomes. However, app-based RT shows promise for maintaining adherence, offering a viable alternative when full supervision is not feasible.},
  langid = {american},
  file = {C\:\\Users\\Paedd\\Zotero\\storage\\CZ9G7AVZ\\Gavanda et al. - 2025 - Optimizing Resistance Training Outcomes Comparing In-Person Supervision, Online Coaching, and Self-.pdf;C\:\\Users\\Paedd\\Zotero\\storage\\UBHFB5YZ\\optimizing_resistance_training_outcomes__comparing.2.html}
}

