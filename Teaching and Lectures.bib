  journal = {Journal of Science and Medicine in Sport},
  volume = {23},
  number = {10},
  pages = {999--1004},
  issn = {1878-1861},
  doi = {10.1016/j.jsams.2020.03.013},
  abstract = {OBJECTIVES: Military-, rescue- and law-enforcement personnel require a high physical capacity including muscular strength. The present study hypothesized that 9 weeks of volume matched concurrent short frequent training sessions increases strength more efficiently than less frequent longer training sessions. DESIGN: A randomized training intervention study with functional and physiological tests before and after the intervention. METHODS: Military conscripts (n=290) were assigned to micro-training (four 15-min strength and four 15-min endurance bouts weekly); classical-training (one 60-min strength and one 60-min endurance training session weekly) or a control-group (two 60-min standard military physical training sessions weekly). RESULTS: There were no group difference between micro-training and classical-training in measures of strength. Standing long jump remained similar while shotput performance was reduced (P{$\leq$}0.001) in all three groups. Pull-up performance increased (P{$\leq$}0.001) in micro-training (7.4\textpm 4.6 vs. 8.5\textpm 4.0 repetitions, n=59) and classical-training (5.7\textpm 4.1 vs. 7.1\textpm 4.2 repetitions, n=50). Knee extensor MVC increased (P{$\leq$}0.01) in all groups (micro-training, n=30, 11.5\textpm 8.9\%; classical-training, n=24, 8.3\textpm 11.5\% and control, n=19, 7.5\textpm 11.8\%) while elbow flexor and hand grip MVC remained similar. Micro-training increased (P{$\leq$}0.05) type IIa percentage from 32.5\textpm 11.0\% to 37.6\textpm 12.3\% (n=20) and control-group increased (P{$\leq$}0.01) type IIax from 4.4\textpm 3.0\% to 11.6\textpm 7.9\% (n=8). In control-group type I, fiber size increased (P{$\leq$}0.05) from 5121\textpm 959{$\mu$}m to 6481\textpm 2084{$\mu$}m (n=5). Satellite cell content remained similar in all groups. CONCLUSIONS: Weekly distribution of low-volume concurrent training completed as either eight 15-min bouts or two 60-min sessions of which 50\% was strength training did not impact strength gains in a real-world setting.},
  langid = {english},
  pmid = {32371120},
  keywords = {/unread,Endurance Training,Female,Healthy Volunteers,Humans,Male,Military,Military Personnel,Muscle biopsies,Muscle fiber composition and size,Muscle Strength,Resistance Training,Satellite cells,Young Adult},
  file = {C\:\\Users\\Paedd\\Zotero\\storage\\7YXISYPV\\Kilen et al. - 2020 - Impact of low-volume concurrent strength training .pdf;C\:\\Users\\Paedd\\Zotero\\storage\\K4V2XTUR\\supplement.pdf}
}

