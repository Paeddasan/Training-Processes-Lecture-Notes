  author = {Cherouveim, Evgenia D. and Methenitis, Spyridon K. and Simeonidis, Theocharis and Georginis, Panagiotis and Tsekouras, Yiannis E. and Biskitzi, Chrisa and Tsolakis, Charis and Koulouvaris, Panagiotis},
  year = 2022,
